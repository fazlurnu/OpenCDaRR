# macOS
.DS_Store

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.ruff_cache/
